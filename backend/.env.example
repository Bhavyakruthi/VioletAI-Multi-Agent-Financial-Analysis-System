# Backend Environment Variables
# ==============================
# Copy this file to .env and fill in your values

# Supabase Configuration
# NOTE: Use the API URL (https://...), NOT the database connection string
SUPABASE_URL=https://nnifonvizhojsbtzcbeh.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Cohere API (for embeddings)
COHERE_API_KEY=your-cohere-api-key

# Google AI (for Gemini LLM)
GOOGLE_API_KEY=your-google-api-key

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db

# Pinecone (Future - for migration)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=your-environment

# Email (SMTP) Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@aiequityresearch.com
